---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Direct Connect Flight Academy — Colorado Springs Flight School',
  description = "FAA Part 141 flight school in Colorado Springs with Self-Examining Authority for Private and Instrument checkrides. Mentored by active airline pilots. Your airline career starts here.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/png" href="/images/logo/dcfa-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url.href} />
  <meta name="theme-color" content="#1e40af" />

  <!-- Open Graph (Facebook, iMessage, Slack, LinkedIn, Discord) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="Direct Connect Flight Academy" />
  <meta property="og:image" content={new URL('/images/aircraft/da42-air.png', Astro.site).href} />
  <meta property="og:image:alt" content="DA42 multi-engine aircraft in flight — Direct Connect Flight Academy" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL('/images/aircraft/da42-air.png', Astro.site).href} />

  <script is:inline>
    (function () {
      try {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      } catch (e) {
        document.documentElement.dataset.theme = 'light';
      }
    })();
  </script>
</head>
<body class="bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100 flex flex-col min-h-screen transition-colors">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
