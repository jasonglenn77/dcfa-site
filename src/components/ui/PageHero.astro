---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  bgImage?: string;
}

const { eyebrow, title, subtitle, bgImage } = Astro.props;
---
<section class="relative overflow-hidden bg-blue-900 dark:bg-slate-900 text-white">
  {bgImage && (
    <div class="absolute inset-0">
      <img src={bgImage} alt="" class="w-full h-full object-cover opacity-25 dark:opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-r from-blue-900/95 via-blue-900/80 to-blue-900/40 dark:from-slate-900/95 dark:via-slate-900/80 dark:to-slate-900/40"></div>
    </div>
  )}
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-24">
    {eyebrow && (
      <div class="inline-block text-xs font-semibold tracking-wide text-blue-200 uppercase">{eyebrow}</div>
    )}
    <h1 class="mt-3 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight">{title}</h1>
    {subtitle && (
      <p class="mt-5 text-base sm:text-lg lg:text-xl text-blue-100 max-w-3xl leading-relaxed">{subtitle}</p>
    )}
  </div>
</section>
