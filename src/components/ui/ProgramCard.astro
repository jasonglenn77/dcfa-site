---
import type { Program } from '../../data/programs';

interface Props {
  program: Program;
}

const { program } = Astro.props;
---
<article id={program.slug} class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden scroll-mt-20">
  <div class="p-6 sm:p-8">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <div class="flex flex-wrap items-center gap-2 text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">
          <span>{program.certificateType}</span>
          {program.vaApproved && (
            <span class="inline-flex items-center rounded-full bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 px-2 py-0.5 text-[10px]">
              VA-Approved
            </span>
          )}
        </div>
        <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">
          {program.name}
        </h2>
      </div>
      <div class="text-right">
        <div class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white">{program.price}</div>
        {program.deposit && (
          <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">+ {program.deposit} deposit</div>
        )}
      </div>
    </div>

    <p class="mt-4 text-base text-slate-600 dark:text-slate-300 leading-relaxed">
      {program.description}
    </p>

    <div class="mt-6 grid sm:grid-cols-2 gap-4 sm:gap-6">
      <div>
        <div class="text-xs font-semibold tracking-wide text-slate-500 dark:text-slate-400 uppercase mb-2">Prerequisite</div>
        <div class="text-sm text-slate-700 dark:text-slate-300">{program.prerequisite}</div>
      </div>
      <div>
        <div class="text-xs font-semibold tracking-wide text-slate-500 dark:text-slate-400 uppercase mb-2">Total Flight Hours</div>
        <div class="text-sm text-slate-700 dark:text-slate-300">{program.totalFlightHours}</div>
      </div>
    </div>

    <div class="mt-6">
      <div class="text-xs font-semibold tracking-wide text-slate-500 dark:text-slate-400 uppercase mb-3">Hours Breakdown</div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {program.hoursBreakdown.map(h => (
          <div class="rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-950 p-3">
            <div class="text-lg font-bold text-slate-900 dark:text-white">{h.hours}</div>
            <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-tight">{h.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-6">
      <div class="text-xs font-semibold tracking-wide text-slate-500 dark:text-slate-400 uppercase mb-3">Highlights</div>
      <ul class="space-y-2">
        {program.highlights.map(h => (
          <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
            <svg class="h-5 w-5 flex-shrink-0 text-blue-700 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8">
      <a href="/contact" class="inline-flex items-center rounded-md bg-blue-700 hover:bg-blue-800 px-5 py-2.5 text-sm font-semibold text-white transition">
        Get started with {program.shortName ?? program.name} →
      </a>
    </div>
  </div>
</article>
