---
interface Props {
  title?: string;
  description?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title = 'Ready to start?',
  description = "A Discovery Flight is the best way to find out if aviation is for you. Take the controls, fly over the Front Range, and decide.",
  primaryHref = '/contact',
  primaryLabel = 'Book a Discovery Flight — $190',
  secondaryHref = 'tel:+17192087049',
  secondaryLabel = 'Call (719) 208-7049',
} = Astro.props;
---
<section class="bg-blue-900 dark:bg-slate-950 text-white py-16 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight">{title}</h2>
    <p class="mt-4 text-base sm:text-lg text-blue-100 dark:text-slate-300">{description}</p>
    <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
      <a href={primaryHref} class="inline-flex items-center justify-center rounded-md bg-white text-blue-900 px-6 py-3 text-base font-semibold hover:bg-blue-50 transition">
        {primaryLabel}
      </a>
      <a href={secondaryHref} class="inline-flex items-center justify-center rounded-md border border-blue-300 dark:border-slate-600 px-6 py-3 text-base font-semibold text-white hover:bg-blue-800 dark:hover:bg-slate-800 transition">
        {secondaryLabel}
      </a>
    </div>
  </div>
</section>
