---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  title: string;
  eyebrow?: string;
  intro?: string;
}

const { title, eyebrow = 'Coming Soon', intro } = Astro.props;
---
<BaseLayout title={`${title} — Direct Connect Flight Academy`}>
  <section class="bg-slate-950 text-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="inline-block text-xs font-semibold tracking-wide text-amber-300 uppercase">{eyebrow}</div>
      <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">{title}</h1>
      {intro && <p class="mt-6 text-lg text-slate-300 max-w-2xl leading-relaxed">{intro}</p>}
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border-2 border-dashed border-slate-300 bg-slate-50 p-10 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-12 w-12 text-slate-400 mx-auto">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
        </svg>
        <p class="mt-4 text-slate-600">
          This page is part of the rebuild and is intentionally a placeholder.
          Content for this page will be drafted with input from the academy.
        </p>
        <a href="/" class="mt-6 inline-flex items-center text-sm font-semibold text-amber-700 hover:text-amber-800">
          ← Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
