---
const year = new Date().getFullYear();

const sections = [
  {
    title: 'Training',
    links: [
      { href: '/training', label: 'All Programs' },
      { href: '/atp-ctp', label: 'ATP-CTP' },
      { href: '/rotor-transition', label: 'Rotor Transition' },
      { href: '/fleet', label: 'Fleet & Rates' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: '/financing', label: 'Financing' },
      { href: '/financing#scholarships', label: 'Scholarships' },
      { href: '/financing/va-benefits', label: 'VA Benefits' },
      { href: '/student-resources', label: 'Student Resources' },
    ],
  },
  {
    title: 'Academy',
    links: [
      { href: '/about', label: 'About DCFA' },
      { href: '/contact', label: 'Contact' },
      { href: 'https://advancedimpressionsinc.com/direct_connect_flight_academy/shop/products/all', label: 'DCFA Swag', external: true },
    ],
  },
];
---
<footer class="bg-slate-900 text-slate-300 mt-auto">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <a href="/" class="inline-flex items-center">
          <img src="/images/logo/dcfa-logo.png" alt="Direct Connect Flight Academy" class="h-9 w-auto brightness-[2.2] contrast-[1.1] saturate-[1.2]" />
        </a>
        <p class="mt-4 text-sm text-slate-400 leading-relaxed">
          FAA Part 141 flight school based at the Colorado Springs Airport. Self-Examining Authority for Private and Instrument checkrides.
        </p>
        <div class="mt-6 flex gap-4">
          <a href="https://www.facebook.com/p/Direct-Connect-Flight-Academy-100063680315409/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white" aria-label="Facebook">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/flydcfa/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white" aria-label="Instagram">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/direct-connect-flight-academy/" target="_blank" rel="noopener" class="text-slate-400 hover:text-white" aria-label="LinkedIn">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      {sections.map(section => (
        <div>
          <h3 class="text-sm font-semibold text-white tracking-wide uppercase">{section.title}</h3>
          <ul class="mt-4 space-y-3">
            {section.links.map(link => (
              <li>
                <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener' } : {})} class="text-sm text-slate-400 hover:text-white transition">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 grid grid-cols-1 md:grid-cols-3 gap-6 text-sm text-slate-400">
      <div>
        <div class="text-white font-semibold mb-1">Visit</div>
        1055 Aviation Way<br />
        Colorado Springs, CO 80916
      </div>
      <div>
        <div class="text-white font-semibold mb-1">Contact</div>
        <a href="tel:+17192087049" class="hover:text-white">(719) 208-7049</a><br />
        <a href="mailto:info@flydcfa.com" class="hover:text-white">info@flydcfa.com</a>
      </div>
      <div>
        <div class="text-white font-semibold mb-1">Hours</div>
        Mon–Fri: 9:00 AM – 5:00 PM<br />
        Sat–Sun: by appointment
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-800 text-xs text-slate-500 text-center">
      © {year} Direct Connect Flight Academy. All rights reserved.
    </div>
  </div>
</footer>
