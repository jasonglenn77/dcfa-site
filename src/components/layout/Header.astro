---
const navItems = [
  { href: '/training', label: 'Training' },
  { href: '/atp-ctp', label: 'ATP-CTP' },
  { href: '/rotor-transition', label: 'Rotor Transition' },
  { href: '/financing', label: 'Financing' },
  { href: '/fleet', label: 'Fleet' },
  { href: '/about', label: 'About' },
];
---
<header class="sticky top-0 z-50 bg-slate-950/95 backdrop-blur border-b border-slate-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-8 w-8">
          <path d="M16 4 L19 14 L28 16 L19 18 L16 28 L13 18 L4 16 L13 14 Z" fill="#fbbf24"/>
        </svg>
        <span class="font-extrabold text-base tracking-tight leading-none">
          DIRECT CONNECT
          <span class="block text-[10px] font-normal text-amber-400 tracking-widest mt-0.5">FLIGHT ACADEMY</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-7">
        {navItems.map(item => (
          <a href={item.href} class="text-sm font-medium text-slate-200 hover:text-white transition">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden lg:block">
        <a href="/contact" class="inline-flex items-center rounded-md bg-amber-400 px-4 py-2 text-sm font-semibold text-slate-950 hover:bg-amber-300 transition">
          Book Discovery Flight
        </a>
      </div>

      <button id="mobile-menu-button" class="lg:hidden text-white p-2 -mr-2" aria-label="Toggle menu" aria-expanded="false">
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6 hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden pb-4 space-y-1">
      {navItems.map(item => (
        <a href={item.href} class="block px-3 py-2 text-base font-medium text-slate-200 hover:text-white hover:bg-slate-800 rounded-md">
          {item.label}
        </a>
      ))}
      <a href="/contact" class="block mt-3 mx-3 rounded-md bg-amber-400 px-4 py-2 text-center text-sm font-semibold text-slate-950">
        Book Discovery Flight
      </a>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  button?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    button.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
