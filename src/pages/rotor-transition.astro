---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';

const militaryRequirements = [
  { hours: 750, label: 'Total Flight Time' },
  { hours: 200, label: 'Cross-Country' },
  { hours: 100, label: 'Night' },
  { hours: 75, label: 'Instrument' },
  { hours: 25, label: 'Multi-Engine' },
];
---
<BaseLayout
  title="Rotor Transition Program — Direct Connect Flight Academy"
  description="Customized fixed-wing training for military and civilian rotorcraft pilots transitioning to airline careers. R-ATP eligible."
>
  <PageHero
    eyebrow="Helicopter to Fixed-Wing"
    title="Rotor Transition Program"
    subtitle="A customized pathway for rotorcraft pilots earning fixed-wing certificates and ratings — accelerated, R-ATP-eligible, and built around the experience you already have."
    bgImage="/images/aircraft/helicopter.jpg"
  />

  <!-- Who it's for -->
  <section class="bg-white dark:bg-slate-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Who this is for</h2>

      <div class="mt-8 grid md:grid-cols-2 gap-6">
        <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Military</div>
          <h3 class="mt-2 text-xl font-bold text-slate-900 dark:text-white">Military rotorcraft pilots</h3>
          <p class="mt-3 text-slate-700 dark:text-slate-300">
            Eligible for Restricted ATP (R-ATP) certificates upon meeting the FAA's military rotor requirements.
          </p>
        </div>
        <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Civilian</div>
          <h3 class="mt-2 text-xl font-bold text-slate-900 dark:text-white">Civilian commercial helicopter pilots</h3>
          <p class="mt-3 text-slate-700 dark:text-slate-300">
            Earn fixed-wing ATP certificates with a customized training plan that recognizes your existing certifications.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Military R-ATP requirements -->
  <section class="bg-slate-50 dark:bg-slate-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Military R-ATP requirements</h2>
      <p class="mt-3 text-base sm:text-lg text-slate-600 dark:text-slate-300 max-w-2xl">
        Military applicants must hold the following minimum flight hours to qualify for the Restricted ATP pathway.
      </p>

      <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
        {militaryRequirements.map(r => (
          <div class="rounded-lg bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-4 sm:p-5 text-center">
            <div class="text-2xl sm:text-3xl font-extrabold text-blue-700 dark:text-blue-400">{r.hours}</div>
            <div class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400 mt-1">hours</div>
            <div class="mt-2 text-sm font-semibold text-slate-900 dark:text-white">{r.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white dark:bg-slate-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <div>
          <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">No entrance exam. Personalized quote.</h2>
          <p class="mt-4 text-base sm:text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            Every rotor pilot's path is different. Your existing ratings, hours, and goals shape the training plan we build for you. Submit the onboarding form and you'll receive an email with the programs you need and a complete cost breakdown.
          </p>
          <p class="mt-4 text-base sm:text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
            Optional: continue with us for fixed-wing time-building after you complete the core programs.
          </p>
          <a href="/contact" class="mt-8 inline-flex items-center rounded-md bg-blue-700 hover:bg-blue-800 px-6 py-3 text-base font-semibold text-white transition">
            Request your custom quote →
          </a>
        </div>

        <div class="rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-6 sm:p-8">
          <h3 class="text-xl font-bold text-slate-900 dark:text-white">What you'll get</h3>
          <ul class="mt-5 space-y-3">
            {[
              'Customized training plan based on your existing ratings',
              'Accelerated fixed-wing pathways',
              'Optional fixed-wing time building after core programs',
              'Personalized quote — no entrance exam required',
              'Tour scheduling availability',
            ].map(item => (
              <li class="flex items-start gap-2 text-slate-700 dark:text-slate-300">
                <svg class="h-5 w-5 mt-0.5 flex-shrink-0 text-blue-700 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaBlock
    title="Ready to transition?"
    description="Submit the rotor transition application and receive your personalized quote by email."
    primaryLabel="Request a Quote"
    secondaryLabel="Call (719) 208-7049"
  />
</BaseLayout>
