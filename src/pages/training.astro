---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import ProgramCard from '../components/ui/ProgramCard.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
import { programs } from '../data/programs';
---
<BaseLayout
  title="Flight Training Programs — Direct Connect Flight Academy"
  description="FAA Part 141 training pathways from Private Pilot through ATP. Transparent pricing, hours, and prerequisites for every program."
>
  <PageHero
    eyebrow="Programs & Pricing"
    title="Every certificate. Every rating."
    subtitle="From your first flight lesson to your Airline Transport Pilot certificate, every program is structured around airline-style training and Part 141 standards. Pricing and required hours are listed up front — no surprise quotes."
    bgImage="/images/cockpit/cockpit-training.jpg"
  />

  <!-- Quick anchor nav -->
  <section class="bg-slate-50 dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 sticky top-16 z-40">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-2 sm:gap-4 overflow-x-auto py-3 -mx-4 px-4 sm:mx-0 sm:px-0 scrollbar-hide">
        {programs.map(p => (
          <a href={`#${p.slug}`} class="flex-shrink-0 text-xs sm:text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-blue-700 dark:hover:text-blue-400 px-3 py-1.5 rounded-md hover:bg-white dark:hover:bg-slate-800 transition whitespace-nowrap">
            {p.shortName ?? p.name}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Accelerated tracks callout -->
  <section class="bg-white dark:bg-slate-950 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 gap-4 sm:gap-6">
        <div class="rounded-xl bg-gradient-to-br from-blue-700 to-blue-900 text-white p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide text-blue-200 uppercase">Accelerated Track</div>
          <div class="mt-2 text-2xl sm:text-3xl font-extrabold">Zero to Commercial</div>
          <div class="mt-1 text-blue-100">in <strong>12–14 months</strong></div>
        </div>
        <div class="rounded-xl bg-gradient-to-br from-blue-700 to-blue-900 text-white p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide text-blue-200 uppercase">Accelerated Track</div>
          <div class="mt-2 text-2xl sm:text-3xl font-extrabold">Instrument to Commercial</div>
          <div class="mt-1 text-blue-100">in <strong>9–11 months</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program list -->
  <section class="bg-slate-50 dark:bg-slate-900 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-6 sm:space-y-8">
        {programs.map(p => <ProgramCard program={p} />)}
      </div>
    </div>
  </section>

  <CtaBlock />
</BaseLayout>
