---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
import { lenders, scholarships } from '../data/financing';
---
<BaseLayout
  title="Financing & Scholarships — Direct Connect Flight Academy"
  description="Flight training financing through Stratus Financial and AOPA, plus scholarship opportunities for student pilots, women in aviation, military, and minority candidates."
>
  <PageHero
    eyebrow="Pay for Your Training"
    title="Financing and scholarships"
    subtitle="Flight training is a real investment. Here's a complete map of the loan partners and scholarships pilots use to make it possible — plus our VA benefits guide for veterans."
  />

  <!-- Lender partners -->
  <section class="bg-white dark:bg-slate-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Loan Partners</div>
      <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Aviation-specific lenders</h2>
      <p class="mt-3 text-base sm:text-lg text-slate-600 dark:text-slate-300 max-w-2xl">
        Both partners specialize in flight training and understand aviation timelines.
      </p>

      <div class="mt-10 grid md:grid-cols-2 gap-6">
        {lenders.map(lender => (
          <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 p-6 sm:p-8 flex flex-col">
            <h3 class="text-2xl font-extrabold text-slate-900 dark:text-white">{lender.name}</h3>
            <p class="mt-3 text-slate-700 dark:text-slate-300 leading-relaxed flex-1">{lender.description}</p>
            <a href={lender.url} target="_blank" rel="noopener" class="mt-6 inline-flex items-center self-start rounded-md bg-blue-700 hover:bg-blue-800 px-5 py-2.5 text-sm font-semibold text-white transition">
              Apply with {lender.name} →
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 rounded-lg bg-blue-50 dark:bg-blue-950/40 border border-blue-200 dark:border-blue-900 p-5 sm:p-6">
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-blue-700 dark:bg-blue-600 flex items-center justify-center">
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-2.21 0-4-1.79-4-4 0-1.13.46-2.15 1.21-2.85" />
            </svg>
          </div>
          <div>
            <div class="font-semibold text-slate-900 dark:text-white">Veteran? You may qualify for VA benefits.</div>
            <div class="text-sm text-slate-700 dark:text-slate-300 mt-1">DCFA accepts Chapters 30, 33, 1606, and 1607. <a href="/financing/va-benefits" class="text-blue-700 dark:text-blue-400 font-semibold hover:underline">See the VA benefits guide →</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Scholarships -->
  <section id="scholarships" class="bg-slate-50 dark:bg-slate-900 py-16 sm:py-20 scroll-mt-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Scholarship Opportunities</div>
      <h2 class="mt-2 text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900 dark:text-white">Scholarships worth applying for</h2>
      <p class="mt-3 text-base sm:text-lg text-slate-600 dark:text-slate-300 max-w-2xl">
        A non-exhaustive list of scholarship programs commonly used by student pilots. Application requirements and deadlines vary — check each organization's site for current details.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5">
        {scholarships.map(s => (
          <div class="rounded-lg bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 p-5 sm:p-6">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-base sm:text-lg font-bold text-slate-900 dark:text-white">{s.organization}</h3>
              <div class="flex-shrink-0 text-right">
                <div class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Award</div>
                <div class="text-sm font-bold text-blue-700 dark:text-blue-400">{s.award}</div>
              </div>
            </div>
            <div class="mt-3 text-sm text-slate-700 dark:text-slate-300">
              <span class="font-semibold">Eligibility:</span> {s.eligibility}
            </div>
            {s.notes && (
              <div class="mt-2 text-sm text-slate-600 dark:text-slate-400">{s.notes}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBlock
    title="Have questions about paying for training?"
    description="We can walk you through which financing or scholarship paths fit your situation. No commitment."
    primaryLabel="Talk to Us"
    secondaryLabel="Call (719) 208-7049"
  />
</BaseLayout>
