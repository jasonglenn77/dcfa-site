---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import CtaBlock from '../components/ui/CtaBlock.astro';
import { aircraft, instructionRate } from '../data/aircraft';
---
<BaseLayout
  title="Aircraft Fleet & Rates — Direct Connect Flight Academy"
  description="DCFA fleet of single- and multi-engine training aircraft. Hourly rental rates for academy graduates and enrolled students. Instruction at $70/hr."
>
  <PageHero
    eyebrow="Our Aircraft"
    title="Fleet and rental rates"
    subtitle="Single- and multi-engine training aircraft, all available to enrolled students and DCFA graduates after the Transition Course. Rates listed are wet, per flight hour."
    bgImage="/images/aircraft/da42-air.png"
  />

  <!-- Aircraft list -->
  <section class="bg-white dark:bg-slate-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">The fleet</h2>

      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {aircraft.map(ac => (
          <div class={`rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden ${ac.image ? 'sm:col-span-2 lg:col-span-3' : ''}`}>
            {ac.image && (
              <div class="aspect-[16/9] bg-slate-100 dark:bg-slate-800 overflow-hidden">
                <img src={ac.image} alt={`${ac.tailNumber} — ${ac.type}`} class="w-full h-full object-cover" />
              </div>
            )}
            <div class="p-5 sm:p-6">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <div class="text-xs font-semibold tracking-wide uppercase text-blue-700 dark:text-blue-400">{ac.type}</div>
                  <div class="mt-1 text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white font-mono">{ac.tailNumber}</div>
                </div>
                <div class="text-right">
                  <div class="text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white">${ac.hourlyRate}</div>
                  <div class="text-xs text-slate-500 dark:text-slate-400">per hour, wet</div>
                </div>
              </div>
              {ac.description && (
                <p class="mt-4 text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{ac.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Wide banner: training in action -->
      <figure class="mt-10 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-slate-900">
        <div class="aspect-[21/9] sm:aspect-[3/1]">
          <img src="/images/aircraft/multi-engine.jpg" alt="DCFA multi-engine training in progress" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <figcaption class="px-5 py-4 text-sm text-slate-600 dark:text-slate-400 border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
          <span class="font-semibold text-slate-900 dark:text-white">Multi-engine training</span> — every commercial pilot and ATP candidate spends real hours in the twin.
        </figcaption>
      </figure>

      <!-- Instruction rate + rules -->
      <div class="mt-10 grid md:grid-cols-2 gap-6">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-900 p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide uppercase text-blue-700 dark:text-blue-400">Flight Instruction</div>
          <div class="mt-2 text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white">${instructionRate}<span class="text-2xl text-slate-500 dark:text-slate-400 font-normal">/hr</span></div>
          <div class="mt-2 text-sm text-slate-700 dark:text-slate-300">CFI rate, in addition to aircraft rental.</div>
        </div>
        <div class="rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-6 sm:p-8">
          <div class="text-xs font-semibold tracking-wide uppercase text-slate-500 dark:text-slate-400">Rental Eligibility</div>
          <div class="mt-2 text-base sm:text-lg font-semibold text-slate-900 dark:text-white">Academy graduates and enrolled students only</div>
          <div class="mt-2 text-sm text-slate-700 dark:text-slate-300">Transition Course completion is required before any aircraft rental.</div>
        </div>
      </div>
    </div>
  </section>

  <CtaBlock
    title="Want to fly?"
    description="Whether you're starting from zero or returning to the cockpit, we can get you behind the yoke."
    primaryLabel="Book a Discovery Flight — $190"
    secondaryLabel="Call (719) 208-7049"
  />
</BaseLayout>
