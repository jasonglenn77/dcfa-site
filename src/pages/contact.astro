---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';

// Web3Forms access key. Sign up at https://web3forms.com (free) to get a key.
// Set PUBLIC_WEB3FORMS_KEY in your .env file (local) and in Cloudflare Pages
// → Settings → Environment Variables (production). Falls back to empty so the
// form fails gracefully when the key isn't set.
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';

const programOptions = [
  'Discovery Flight to Airline Pilot Accelerated Program',
  'Continuing training with DCFA',
  'MSU Student / RATP program',
  'RTP — Rotary to Fixed-Wing Transition',
  'ATP-CTP Program',
  'Unsure / want to learn more',
];

const referralOptions = [
  'Search Engine',
  'Word of Mouth',
  'MSU Program',
  'Employee Reference',
  'Other',
];
---
<BaseLayout
  title="Contact & Discovery Flight — Direct Connect Flight Academy"
  description="Schedule a Discovery Flight, request a custom training quote, or get in touch with DCFA. Located at 1055 Aviation Way, Colorado Springs."
>
  <PageHero
    eyebrow="Get in touch"
    title="Book a Discovery Flight or request information."
    subtitle="A Discovery Flight is $190 and the best way to find out if aviation is for you. For everything else — quotes, ATP-CTP scheduling, RTP, VA benefits — submit the form and we'll be in touch within one business day."
  />

  <section class="bg-white dark:bg-slate-950 py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Contact info column -->
        <div class="lg:col-span-1 space-y-6">
          <div>
            <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Call</div>
            <a href="tel:+17192087049" class="mt-1 block text-2xl sm:text-3xl font-extrabold text-slate-900 dark:text-white hover:text-blue-700 dark:hover:text-blue-400 transition">
              (719) 208-7049
            </a>
          </div>
          <div>
            <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Email</div>
            <a href="mailto:info@flydcfa.com" class="mt-1 block text-lg sm:text-xl font-bold text-slate-900 dark:text-white hover:text-blue-700 dark:hover:text-blue-400 transition break-all">
              info@flydcfa.com
            </a>
          </div>
          <div>
            <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Visit</div>
            <a href="https://maps.google.com/?q=1055+Aviation+Way+Colorado+Springs+CO+80916" target="_blank" rel="noopener" class="mt-1 block font-semibold text-slate-900 dark:text-white hover:text-blue-700 dark:hover:text-blue-400 transition">
              1055 Aviation Way<br />
              Colorado Springs, CO 80916
            </a>
          </div>
          <div>
            <div class="text-xs font-semibold tracking-wide text-blue-700 dark:text-blue-400 uppercase">Hours</div>
            <div class="mt-1 text-slate-700 dark:text-slate-300">
              <div>Mon–Fri: 9:00 AM – 5:00 PM</div>
              <div>Sat–Sun: by appointment</div>
            </div>
          </div>

          <!-- Map embed -->
          <div class="rounded-lg overflow-hidden border border-slate-200 dark:border-slate-800 aspect-[4/3] bg-slate-100 dark:bg-slate-900">
            <iframe
              src="https://www.google.com/maps/embed/v1/place?key=&q=1055+Aviation+Way+Colorado+Springs+CO+80916"
              width="100%"
              height="100%"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Map to DCFA"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <!-- Form column -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Information request form</h2>
          <p class="mt-2 text-slate-600 dark:text-slate-400">We typically respond within one business day.</p>

          {!web3formsKey && (
            <div class="mt-4 rounded-md border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-950/40 text-amber-900 dark:text-amber-200 px-4 py-3 text-sm">
              <strong>Setup needed:</strong> The form will not actually send messages until a Web3Forms access key is added.
              Sign up free at <a href="https://web3forms.com" target="_blank" rel="noopener" class="underline">web3forms.com</a>,
              then set <code class="font-mono text-xs bg-amber-100 dark:bg-amber-900/60 px-1 rounded">PUBLIC_WEB3FORMS_KEY</code> in your <code class="font-mono text-xs bg-amber-100 dark:bg-amber-900/60 px-1 rounded">.env</code> file and in Cloudflare Pages environment variables.
            </div>
          )}

          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="mt-8 space-y-5"
          >
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="DCFA — New Information Request" />
            <input type="hidden" name="from_name" value="DCFA Website" />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="first_name" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">First name <span class="text-red-600">*</span></label>
                <input type="text" id="first_name" name="first_name" required autocomplete="given-name"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2 focus:ring-offset-0" />
              </div>
              <div>
                <label for="last_name" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Last name <span class="text-red-600">*</span></label>
                <input type="text" id="last_name" name="last_name" required autocomplete="family-name"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Email <span class="text-red-600">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" inputmode="email"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Phone <span class="text-red-600">*</span></label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel" inputmode="tel"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2" />
              </div>
            </div>

            <div>
              <label for="program_interest" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Program interest <span class="text-red-600">*</span></label>
              <select id="program_interest" name="program_interest" required
                class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2">
                <option value="">Select a program…</option>
                {programOptions.map(opt => <option value={opt}>{opt}</option>)}
              </select>
            </div>

            <div>
              <label for="aviation_experience" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Previous aviation experience</label>
              <textarea id="aviation_experience" name="aviation_experience" rows="3"
                class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2"
                placeholder="Certificates held, hours, recent flying — anything you'd like us to know."></textarea>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="current_location" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Current location</label>
                <input type="text" id="current_location" name="current_location" autocomplete="address-level2"
                  placeholder="City, State"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2" />
              </div>
              <div>
                <label for="referral" class="block text-sm font-semibold text-slate-700 dark:text-slate-300">How did you hear about us?</label>
                <select id="referral" name="referral"
                  class="mt-1.5 block w-full rounded-md border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 text-slate-900 dark:text-white px-3 py-2.5 shadow-sm focus:border-blue-500 focus:ring-blue-500 focus:outline-none focus:ring-2">
                  <option value="">Select…</option>
                  {referralOptions.map(opt => <option value={opt}>{opt}</option>)}
                </select>
              </div>
            </div>

            <div class="pt-2">
              <button type="submit"
                class="w-full sm:w-auto inline-flex justify-center items-center rounded-md bg-blue-700 hover:bg-blue-800 px-8 py-3 text-base font-semibold text-white transition shadow-sm">
                Send Information Request
              </button>
            </div>

            <p class="text-xs text-slate-500 dark:text-slate-400">
              By submitting, you consent to be contacted by DCFA about your inquiry.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
